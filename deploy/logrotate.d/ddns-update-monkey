# File:        /etc/logrotate.d/ddns-update-monkey
# Purpose:     Rotate the cron log so /var/log doesn't grow unbounded
# Owner:       root:root, Permissions: 644

/var/log/ddns-update-monkey-cron.log {
    weekly
    rotate 4
    compress
    delaycompress
    missingok
    notifempty
    create 0644 pi pi
}
